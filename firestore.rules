rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isParticipant() {
      return isSignedIn() && request.auth.uid in resource.data.participants;
    }

    function isIncomingParticipant() {
      return isSignedIn() && request.auth.uid in request.resource.data.participants;
    }

    match /chat_rooms/{chatRoomId} {
      allow read: if isParticipant();

      allow create: if isIncomingParticipant()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.buyerId in request.resource.data.participants
        && request.resource.data.sellerId in request.resource.data.participants;

      allow update: if isParticipant()
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.buyerId == resource.data.buyerId
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.listingId == resource.data.listingId;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participants;

        allow create: if isSignedIn()
          && request.auth.uid in getAfter(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participants
          && request.resource.data.chatRoomId == chatRoomId
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.receiverId in getAfter(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participants
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(chatRoomId)).data.participants
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead'])
          && resource.data.receiverId == request.auth.uid;

        allow delete: if false;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /user_metadata/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.sellerId == request.auth.uid;

      allow update: if isSignedIn()
        && (
          resource.data.sellerId == request.auth.uid
          || request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['mineTaken', 'stealTaken', 'grabTaken'])
        );

      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
